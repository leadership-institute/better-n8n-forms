{
  "name": "n8n-nodes-betterforms",
  "version": "0.1.4",
  "description": "BetterForms custom form trigger node for n8n",
  "license": "MIT",
  "author": {
    "name": "CTFries",
    "email": "me@ctfries.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/leadership-institute/better-n8n-forms.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "forms",
    "betterforms",
    "better.forms"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/BetterFormsApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/CustomFormTrigger/CustomFormTrigger.node.js"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@n8n/node-cli": "*",
    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
